# Copy this file to `.env` before the first `docker compose up`:
#   cp .env.example .env       (Linux/macOS)
#   Copy-Item .env.example .env   (PowerShell)
#
# The backend reads & writes this file through the Settings UI. It is
# bind-mounted into the container at /app/.env; if the file is missing on
# the host, Docker will silently create a DIRECTORY with the same name,
# breaking settings persistence. Compose is configured with
# create_host_path:false so that mistake fails loudly instead.

# Basic auth in front of the UI/API (true/false)
AUTH_ENABLED=false
AUTH_USER=admin
AUTH_PASS=changeme

# How long to keep uploads/outputs on disk (hours)
FILE_RETENTION_HOURS=1

# Redis (inside the container; leave as default unless you changed supervisord)
REDIS_URL=redis://127.0.0.1:6379/0

# Celery: how many compression jobs can run at once (each is one FFmpeg). Default 4.
# Increase (e.g. 8–16) to use more CPU when queuing multiple files; SVT-AV1 cannot
# “max one core” per job by design (see SVT lp=6 cap). Restart container after change.
WORKER_CONCURRENCY=4

# Backend bind
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# Persist completed job history (JSON on disk). true/false
HISTORY_ENABLED=true

# --- Logging ----------------------------------------------------------------
# Root level (INFO|DEBUG|WARNING|ERROR)
LOG_LEVEL=INFO
# Override verbosity for 8mb.local's own code (app.* / worker.*). Set to DEBUG
# to see per-request, per-job, FFmpeg command, hw-cache and cleanup traces.
LOG_LEVEL_APP=INFO
# Uvicorn access log verbosity (one line per HTTP request). Default WARNING
# keeps logs clean; set to INFO if you want full access-log output.
LOG_LEVEL_UVICORN=WARNING
